# NetMap — Configuration
# Copier en .env et renseigner les valeurs
# cp .env.example .env

# ── Réseau ─────────────────────────────────────────────────────────────────
# Port d'exposition de l'interface web
NETMAP_PORT=8080

# ── Secrets ────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET=
JWT_REFRESH_SECRET=
AGENT_TOKEN_SALT=

# ── Administrateur ─────────────────────────────────────────────────────────
# Mot de passe du compte admin au premier démarrage
# Si vide : généré aléatoirement et affiché dans les logs
NETMAP_ADMIN_PASS=

# ── Scanner ────────────────────────────────────────────────────────────────
# Token créé automatiquement par setup.sh
# Ou manuellement via l'interface admin (scope: scanner)
SCANNER_TOKEN=

# CIDRs à scanner, séparés par des virgules
SCAN_NETWORKS=192.168.1.0/24

# Intervalle entre deux scans complets (secondes)
SCAN_INTERVAL=300

# Arguments nmap (ajuster -T4 en -T3 sur réseaux lents)
NMAP_ARGS=-sV --top-ports 50 -O --osscan-limit -T4

# ── Proxmox (optionnel) ────────────────────────────────────────────────────
PROXMOX_HOST=
PROXMOX_USER=root@pam
PROXMOX_PASS=
PROXMOX_POLL=60
# 0 = ignorer les certificats auto-signés (homelab)
PROXMOX_TLS=0
